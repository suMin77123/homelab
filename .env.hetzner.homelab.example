# ------------------------------------------------------------
# .env.hetzner.homelab — template for the 'homelab' env on Hetzner.
#
# Usage:
#   cp .env.hetzner.homelab.example .env.hetzner.homelab
#   # edit .env.hetzner.homelab with real values
#   just envs   # symlink it as .env
#
# Committed: THIS FILE (with placeholders, ends in .example)
# Gitignored: .env, .env.hetzner.homelab (real values)
# ------------------------------------------------------------

# --- Repo routing (used by Justfile to resolve paths) ---
ENV=homelab
CSP=hetzner
PROJECT=homelab

# --- Hetzner Cloud (https://console.hetzner.cloud → Security → API Tokens) ---
# Needs Read & Write. Consumed by the hcloud provider and the hcloud CLI.
HCLOUD_TOKEN=

# --- Cloudflare R2 (Terraform state backend, S3-compatible) ---
# Dashboard → R2 → Manage R2 API Tokens → Create API token.
# Permission: "Object Read & Write". Scope to the STATE_BUCKET below.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are the standard names the
# S3 provider reads from env; they hold R2 credentials, not AWS ones.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# R2 always uses "auto" as the region.
AWS_REGION=auto
# Endpoint includes your Cloudflare account ID. Find it in the R2 overview
# page (or on any zone's overview page, right-side "API" section).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Bucket that holds all tfstate (one bucket + per-stack key prefix).
# Pick something namespaced — R2 bucket names are per-account, not global.
STATE_BUCKET=homelab-tfstate

# --- Cloudflare (DNS + Tunnel, Phase 4) ---
# My Profile → API Tokens. Needs Zone > DNS > Edit + Account > Cloudflare Tunnel > Edit.
# This is a SEPARATE token from the R2 one above (different scopes).
CLOUDFLARE_API_TOKEN=
# From your domain's Overview page (right-side API section).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# The domain itself — no scheme, no trailing slash.
DOMAIN=example.xyz

# --- Tailscale (Phase 4) ---
# Admin Console → Settings → Keys → Generate auth key (Reusable ON, Ephemeral OFF).
TAILSCALE_AUTHKEY=

# --- Infisical (Phase 7 — leave blank until then) ---
INFISICAL_API_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
